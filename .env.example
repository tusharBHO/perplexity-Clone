# ==============================
# 🌐 APP CONFIG
# ==============================
NODE_ENV=development
PORT=3000

# ==============================
# 🔐 AUTH (Clerk)
# ==============================

# Public key (safe for frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

# Secret key (NEVER expose in frontend)
CLERK_SECRET_KEY=your_clerk_secret_key

# Auth routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Redirects after auth
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ==============================
# 🗄 DATABASE (Supabase)
# ==============================

# Project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Public anon key (safe for frontend but still don't hardcode)
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_anon_key

# ==============================
# 🤖 AI APIs
# ==============================

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# Public Gemini key (if used on client)
NEXT_PUBLIC_GEMINI_API_KEY=your_public_gemini_key

# Brave Search API
BRAVE_API_KEY=your_brave_api_key

# ==============================
# ⚙️ BACKGROUND JOBS (Inngest)
# ==============================

# Signing key for webhook validation
INNGEST_SIGNING_KEY=your_inngest_signing_key

# Local dev server
INNGEST_SERVER_HOST=http://127.0.0.1:8288

# ==============================
# 📧 EMAIL (EmailJS)
# ==============================

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
